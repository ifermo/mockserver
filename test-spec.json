[
  {
    "name": "get user by id",
    "httpRequest": {
      "method": "GET",
      "path": "/api/user/:id"
    },
    "httpResponse": {
      "statusCode": 200,
      "headers": {
        "Content-Type": "application/json"
      },
      "body": "{\"id\":1,\"name\":\"张三\",\"email\":\"zhangsan@example.com\"}"
    }
  },
  {
    "name": "login",
    "httpRequest": {
      "method": "POST",
      "path": "/api/login",
      "body": { "username": "admin", "password": "123456" }
    },
    "httpResponse": {
      "statusCode": 200,
      "body": "{\"token\":\"fake-jwt-token\",\"expires_in\":3600}"
    }
  },
  {
    "name": "login failed",
    "httpRequest": {
      "method": "POST",
      "path": "/api/login"
    },
    "httpResponse": {
      "statusCode": 401,
      "body": "{\"error\":\"用户名或密码错误\"}"
    }
  },
  {
    "name": "get product by id",
    "httpRequest": {
      "method": "GET",
      "path": "/api/products/[0-9]+"
    },
    "httpResponse": {
      "statusCode": 200,
      "body": "{\"id\":1,\"name\":\"商品名称\",\"price\":99.00}",
      "delay": {
        "timeUnit": "SECONDS",
        "value": 2
      }
    }
  }
]
